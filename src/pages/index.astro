---
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
const projects = allProjects.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const categories = [...new Set(projects.map((p) => p.data.category))];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Nathan's Showcase</title>
    <style>
      :root {
        color-scheme: light dark;
        --chelsea-blue: #034694;
        --chelsea-blue-light: #1b5ec2;
        --chelsea-blue-dark: #022c5e;
        --ink: #16202b;
        --paper: #ffffff;
        --paper-muted: #f4f7fb;
        --border: rgba(3, 70, 148, 0.12);
        --shadow: rgba(3, 70, 148, 0.16);
        --space-1: 0.5rem;
        --space-2: 1rem;
        --space-3: 1.5rem;
        --space-4: 2.5rem;
        --space-5: 4rem;
        --radius: 14px;
      }
      * {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
        margin: 0;
        color: var(--ink);
        background: var(--paper-muted);
        -webkit-font-smoothing: antialiased;
      }
      @media (prefers-color-scheme: dark) {
        body {
          background: #0b1420;
          color: #eef3fb;
        }
      }
      a {
        color: inherit;
      }
      :focus-visible {
        outline: 3px solid var(--chelsea-blue-light);
        outline-offset: 2px;
      }

      .hero {
        position: relative;
        background: linear-gradient(135deg, var(--chelsea-blue-dark), var(--chelsea-blue) 55%, var(--chelsea-blue-light));
        color: #fff;
        padding: var(--space-5) var(--space-3) var(--space-4);
        border-radius: 0 0 32px 32px;
        overflow: hidden;
      }
      .hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 85% -10%, rgba(255, 255, 255, 0.18), transparent 55%);
        pointer-events: none;
      }
      .hero-inner {
        position: relative;
        max-width: 1080px;
        margin: 0 auto;
      }
      h1 {
        font-size: clamp(2rem, 1.5rem + 2vw, 2.75rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        margin: 0 0 0.5rem;
      }
      .subtitle {
        font-size: 1.05rem;
        opacity: 0.88;
        margin: 0;
        max-width: 34ch;
      }

      main {
        max-width: 1080px;
        margin: 0 auto;
        padding: var(--space-4) var(--space-3) 0;
      }

      .filters {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin-bottom: var(--space-4);
      }
      .filters button {
        font: inherit;
        font-size: 0.9rem;
        font-weight: 600;
        padding: 0.5rem 1.1rem;
        border-radius: 999px;
        border: 1.5px solid var(--border);
        background: var(--paper);
        color: var(--chelsea-blue);
        cursor: pointer;
        transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease, transform 0.1s ease;
      }
      .filters button:hover {
        border-color: var(--chelsea-blue-light);
        transform: translateY(-1px);
      }
      @media (prefers-color-scheme: dark) {
        .filters button {
          background: #101c2c;
          border-color: rgba(120, 170, 255, 0.25);
          color: #cfe0ff;
        }
        .to-be-continued {
          color: #cfe0ff;
        }
      }
      .filters button.active {
        background: var(--chelsea-blue);
        border-color: var(--chelsea-blue);
        color: #fff;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
        gap: var(--space-3);
      }
      .card {
        text-decoration: none;
        color: inherit;
        display: block;
        background: var(--paper);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 0.6rem;
        transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
      }
      @media (prefers-color-scheme: dark) {
        .card {
          background: #101c2c;
          border-color: rgba(120, 170, 255, 0.18);
        }
      }
      .card:hover {
        transform: translateY(-4px);
        box-shadow: 0 14px 28px -8px var(--shadow);
        border-color: var(--chelsea-blue-light);
      }
      .card .thumb {
        overflow: hidden;
        border-radius: 8px;
        aspect-ratio: 4 / 3;
      }
      .card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.3s ease;
      }
      .card:hover img {
        transform: scale(1.04);
      }
      .card h2 {
        font-size: 1rem;
        font-weight: 700;
        margin: 0.75rem 0.2rem 0.4rem;
      }
      .card .category {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--chelsea-blue);
        background: rgba(3, 70, 148, 0.08);
        padding: 0.2rem 0.55rem;
        border-radius: 999px;
        margin: 0 0.2rem 0.2rem;
      }
      @media (prefers-color-scheme: dark) {
        .card .category {
          color: #cfe0ff;
          background: rgba(120, 170, 255, 0.15);
        }
      }

      footer {
        max-width: 1080px;
        margin: var(--space-5) auto 0;
        padding: var(--space-4) var(--space-3) var(--space-5);
        text-align: center;
        border-top: 1px solid var(--border);
      }
      .to-be-continued {
        font-style: italic;
        font-weight: 600;
        color: var(--chelsea-blue);
        margin: 0;
      }
    </style>
  </head>
  <body>
    <header class="hero">
      <div class="hero-inner">
        <h1>Nathan's Showcase</h1>
        <p class="subtitle">Art, product design, and other things I've made.</p>
      </div>
    </header>

    <main>
      <div class="filters" id="filters">
        <button class="active" data-category="all">All</button>
        {categories.map((c) => <button data-category={c}>{c}</button>)}
      </div>

      <div class="grid" id="grid">
        {
          projects.map((project) => (
            <a class="card" data-category={project.data.category} href={`/projects/${project.id}/`}>
              <div class="thumb">
                <img src={project.data.coverImage} alt={project.data.title} />
              </div>
              <h2>{project.data.title}</h2>
              <span class="category">{project.data.category}</span>
            </a>
          ))
        }
      </div>
    </main>

    <footer>
      <p class="to-be-continued">To be continued&hellip;</p>
    </footer>

    <script>
      const buttons = document.querySelectorAll("#filters button");
      const cards = document.querySelectorAll("#grid .card");
      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          buttons.forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
          const category = btn.getAttribute("data-category");
          cards.forEach((card) => {
            const match = category === "all" || card.getAttribute("data-category") === category;
            (card as HTMLElement).style.display = match ? "" : "none";
          });
        });
      });
    </script>
  </body>
</html>

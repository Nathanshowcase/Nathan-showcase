---
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
const projects = allProjects.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const categories = [...new Set(projects.map((p) => p.data.category))];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Nathan's Showcase</title>
    <style>
      :root {
        color-scheme: light dark;
        --chelsea-blue: #034694;
        --chelsea-blue-light: #1b5ec2;
      }
      body {
        font-family: system-ui, sans-serif;
        margin: 0;
        padding: 0 0 4rem;
        background: #f4f7fb;
      }
      @media (prefers-color-scheme: dark) {
        body {
          background: #0c1520;
        }
      }
      .hero {
        background: linear-gradient(135deg, var(--chelsea-blue), var(--chelsea-blue-light));
        color: #fff;
        padding: 3rem 1.5rem 2.5rem;
        border-radius: 0 0 28px 28px;
        margin-bottom: 2rem;
      }
      .hero-inner {
        max-width: 1000px;
        margin: 0 auto;
      }
      h1 {
        font-size: 2rem;
        margin-bottom: 0.35rem;
      }
      .subtitle {
        opacity: 0.85;
        margin-top: 0;
      }
      main {
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }
      .filters {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 2rem;
      }
      .filters button {
        font: inherit;
        padding: 0.4rem 0.9rem;
        border-radius: 999px;
        border: 1px solid var(--chelsea-blue);
        background: none;
        color: var(--chelsea-blue);
        cursor: pointer;
        opacity: 0.75;
      }
      @media (prefers-color-scheme: dark) {
        .filters button {
          border-color: var(--chelsea-blue-light);
          color: #cfe0ff;
        }
      }
      .filters button.active {
        opacity: 1;
        font-weight: 600;
        background: var(--chelsea-blue);
        color: #fff;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 1.5rem;
      }
      .card {
        text-decoration: none;
        color: inherit;
        display: block;
        border-radius: 10px;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
      }
      .card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(3, 70, 148, 0.25);
      }
      .card img {
        width: 100%;
        aspect-ratio: 4 / 3;
        object-fit: cover;
        border-radius: 8px;
        display: block;
      }
      .card h2 {
        font-size: 1rem;
        margin: 0.5rem 0 0.15rem;
      }
      .card .category {
        font-size: 0.85rem;
        opacity: 0.6;
        margin: 0;
      }
      .to-be-continued {
        text-align: center;
        font-style: italic;
        opacity: 0.55;
        margin-top: 3rem;
      }
    </style>
  </head>
  <body>
    <div class="hero">
      <div class="hero-inner">
        <h1>Nathan's Showcase</h1>
        <p class="subtitle">Art, product design, and other things I've made.</p>
      </div>
    </div>

    <main>
      <div class="filters" id="filters">
        <button class="active" data-category="all">All</button>
        {categories.map((c) => <button data-category={c}>{c}</button>)}
      </div>

      <div class="grid" id="grid">
        {
          projects.map((project) => (
            <a class="card" data-category={project.data.category} href={`/projects/${project.id}/`}>
              <img src={project.data.coverImage} alt={project.data.title} />
              <h2>{project.data.title}</h2>
              <p class="category">{project.data.category}</p>
            </a>
          ))
        }
      </div>

      <p class="to-be-continued">To be continued&hellip;</p>
    </main>

    <script>
      const buttons = document.querySelectorAll("#filters button");
      const cards = document.querySelectorAll("#grid .card");
      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          buttons.forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
          const category = btn.getAttribute("data-category");
          cards.forEach((card) => {
            const match = category === "all" || card.getAttribute("data-category") === category;
            (card as HTMLElement).style.display = match ? "" : "none";
          });
        });
      });
    </script>
  </body>
</html>
